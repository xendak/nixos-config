#!/usr/bin/env bash
set -euo pipefail

if [ $# -eq 0 ]; then
  echo "Usage: $0 <ai-command> [additional-args...]"
  exit 1
fi

AI_COMMAND="$1"
shift

if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  echo "Error: Not a Git repository."
  exit 1
fi

if git diff --cached --quiet; then
  echo "No staged changes detected."
  exit 0
fi

RECENT_COMMITS=$(git log -n 5 --pretty=format:'%h %s')
DIFF=$(git --no-pager diff --no-color --no-ext-diff --cached)

PROMPT="Task: Generate 3-5 Conventional Commit options based on the provided DIFF.

STRICT RULES:
1. Format: 
   <type>(<scope>): <short summary>
   Desc: <concise bullet point of what was changed and why>

2. Style: Be technical, concise, and descriptive.
3. Types: feat, fix, docs, style, refactor, perf, test, chore, build.
4. Separation: Separate each option with exactly '---' on a new line.
5. Content: No intro, no markdown blocks, no 'Here are your commits'.

EXAMPLE:
feat(tui): improved rendering
Desc: optimized buffer clearing logic to prevent flickering on high-refresh displays
---
fix(auth): secure token storage
Desc: migrated session tokens from localStorage to HttpOnly cookies to mitigate XSS

RECENT CONTEXT:
$RECENT_COMMITS

DIFF TO ANALYZE:
$DIFF"

selected_commit_message=$(
  echo "$PROMPT" | "$AI_COMMAND" "$@" |
    awk 'BEGIN {RS="---"} NF {
          sub(/^[[:space:]-]+/, "");
          sub(/[[:space:]]+$/, "");
          printf "%s%c", $0, 0
        }' |
    fzf --height 40% --border --ansi --read0 --no-sort \
      --header "Select a commit message (ESC to cancel)" \
      --preview 'echo {}' \
      --preview-window=down:3:wrap)

if [ -z "$selected_commit_message" ]; then
  echo "Aborted: No message selected."
  exit 0
fi

COMMIT_MSG_FILE=$(mktemp)
echo "$selected_commit_message" > "$COMMIT_MSG_FILE"

${EDITOR:-hx} "$COMMIT_MSG_FILE"

if [ -s "$COMMIT_MSG_FILE" ]; then
  git commit -F "$COMMIT_MSG_FILE"
  echo "Committed successfully!"
else
  echo "Commit aborted: Message was not saved nor edited."
fi

rm -f "$COMMIT_MSG_FILE"
