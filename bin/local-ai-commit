#!/usr/bin/env bash
set -euo pipefail

MODEL_CHANGES="${GIT_GEN_CHANGES_MODEL:-tavernari/git-commit-message:sp_change_mini}"
MODEL_COMMIT="${GIT_GEN_COMMIT_MODEL:-tavernari/git-commit-message:sp_commit_mini}"
EDITOR_CMD="${EDITOR:-hx}"

while [[ $# -gt 0 ]]; do
  case "$1" in
    -ch) MODEL_CHANGES="$2"; shift 2 ;;
    -cm) MODEL_COMMIT="$2"; shift 2 ;;
    -h|--help)
      echo "Usage: git-cc-pro [-ch change_model] [-cm commit_model]"
      exit 0
      ;;
    *) shift ;;
  esac
done

if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
  echo -e "\033[31m[ERROR]\033[0m Not a Git repository." >&2
  exit 1
fi

DIFF="$(git diff --staged -U5 --no-color)"
if [ -z "$DIFF" ]; then
  echo -e "\033[33m[WARN]\033[0m No staged changes. Run 'git add' first." >&2
  exit 1
fi

PREV_COMMITS="$(git log --pretty=format:%s -n 10 2>/dev/null || echo "(no previous commits)")"

echo -e "\033[34m[1/3] Deep Analysis (\033[36m$MODEL_CHANGES\033[34m)...\033[0m" >&2

split_diff() {
  local diff_content="$1" chunk=""; 
  while IFS= read -r line; do
    if [[ "$line" =~ ^diff\ --git\  ]]; then
      if [ -n "$chunk" ]; then echo "$chunk"; echo "---FILE_BOUNDARY---"; fi
      chunk="$line"$'\n'
    else chunk+="$line"$'\n'; fi
  done <<< "$diff_content"
  echo "$chunk"
}

ACCUMULATED_CHANGES=""
while IFS= read -r chunk; do
  [ -z "$chunk" ] && continue
  FILE_NAME=$(echo "$chunk" | head -n 1 | sed -e 's#.* b/##')
  
  echo -ne "    \033[90m→ $FILE_NAME... \033[0m" >&2
 
  INPUT_CHUNK="<diff>\n$chunk\n</diff>"
  
  SUMMARY=$(ollama run "$MODEL_CHANGES" "$INPUT_CHUNK" 2>/dev/null || echo "Changed $FILE_NAME")
  echo -e "\033[32mDone\033[0m" >&2
  
  ACCUMULATED_CHANGES+="<file name=\"$FILE_NAME\">\n$SUMMARY\n</file>\n"
done < <(split_diff "$DIFF")

echo -e "\033[34m[2/3] Synthesizing Titles (\033[36m$MODEL_COMMIT\033[34m)...\033[0m" >&2

TITLES_PROMPT="<previous_context>\n$PREV_COMMITS\n</previous_context>\n<all_changes>\n$ACCUMULATED_CHANGES\n</all_changes>
You are an expert developer. Generate a git commit subject and an extended description for these changes.
The subject MUST follow \"Conventional Commits\" format (e.g., 'feat: add login', 'fix: resolve crash').
Keep the subject <= 72 characters and do not wrap it in quotes.
The body should be 2-4 short lines explaining what changed and why (no code blocks).
Return STRICT only the lines.:
"

TITLE_OPTIONS=$(ollama run "$MODEL_COMMIT" "$TITLES_PROMPT" 2>/dev/null)

CLEAN_DESC=$(echo -e "$ACCUMULATED_CHANGES" | sed -e 's/<[^>]*>//g' | sed '/^[[:space:]]*$/d' | sed 's/^[[:space:]]*/- /')
PREVIEW_FILE=$(mktemp)
printf "Detailed Technical Analysis:\n%s\n" "$CLEAN_DESC" > "$PREVIEW_FILE"
SELECTED_TITLE=$(echo "$TITLE_OPTIONS" | fzf --height 40% --border --ansi \
  --header "Select Title (Full Analysis will be appended below)" \
  --preview "cat $PREVIEW_FILE")
rm -f "$PREVIEW_FILE"

COMMIT_MSG_FILE=$(mktemp)
{
  echo "$SELECTED_TITLE"
  echo ""
  echo "$CLEAN_DESC"
} > "$COMMIT_MSG_FILE"

$EDITOR_CMD "$COMMIT_MSG_FILE"

if [ -s "$COMMIT_MSG_FILE" ]; then
  git commit -F "$COMMIT_MSG_FILE"
  echo -e "\033[32m[OK] Successfully committed!\033[0m"
else
  echo "Commit aborted: Message was cleared."
fi

rm -f "$COMMIT_MSG_FILE"
