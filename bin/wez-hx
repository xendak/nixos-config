#!/usr/bin/env bash

LOC=$1

TARGET_PANE_ID=$(zellij action list-panes | grep "Editor" | awk '{print $1}' | cut -d '_' -f 2)

if [ -z "$TARGET_PANE_ID" ]; then
    zellij action new-pane --direction left -- hx "$LOC"
    exit 0
fi

PANE_COMMAND=$(zellij action list-panes --json | jq -r ".. | objects | select(.id? == $TARGET_PANE_ID) | .pane_command?" 2>/dev/null)


zellij action focus-pane-id "$TARGET_PANE_ID"

if [[ "$PANE_COMMAND" == *"hx"* ]] || [[ "$PANE_COMMAND" == *"helix"* ]]; then
    zellij action write 27 --pane-id "$TARGET_PANE_ID"
    sleep 0.05
    zellij action write-chars ":open $LOC" --pane-id "$TARGET_PANE_ID"
    zellij action write 13 --pane-id "$TARGET_PANE_ID"
else
    zellij action write-chars "hx $LOC" --pane-id "$TARGET_PANE_ID"
    zellij action write 13 --pane-id "$TARGET_PANE_ID"
fi
